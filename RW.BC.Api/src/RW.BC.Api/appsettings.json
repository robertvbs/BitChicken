{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Identity": {
    "Firebase": {
      "ProjectId": "your-firebase-project-id"
    }
  },
  "Cors": {
    "Origins": [ "https://localhost:4200", "http://localhost:4200" ],
    "AllowedHostSuffixes": [ ".example.com" ]
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 10,
      "QueueLimit": 0
    },
    "WalletPolicy": {
      "PolicyName": "wallet-link",
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  }
}
