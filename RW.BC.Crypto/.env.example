# RW.BC.Crypto — variaveis de ambiente (copie para .env e preencha; NUNCA commite o .env real)

# Token (deploy)
TOKEN_NAME="BitChicken Token"
TOKEN_SYMBOL="BCKN"

# RPCs
BSC_RPC_URL="https://bsc-dataseed.binance.org"
BSC_TESTNET_RPC_URL="https://data-seed-prebsc-1-s1.binance.org:8545"

# Verificacao de contratos (BSCScan)
BSCSCAN_API_KEY=""

# Chave de deploy (NUNCA versionar; use uma carteira dedicada)
MAIN_PRIVATE_KEY=""

# Governanca (deploy): carteira que recebe DEFAULT_ADMIN_ROLE do token e a
# ownership de NFT/Staking/Marketplace. Se vazia, o proprio deployer permanece
# como admin/owner (comportamento seguro para localhost/testnet).
ADMIN_WALLET=""

# Marketplace: destino da taxa de plataforma (default: o deployer) e a taxa em
# basis points (250 = 2.5%).
FEE_SINK=""
PLATFORM_FEE_BPS="250"

# Chainlink VRF (Forge). No localnet, o coordinator/subId sao gerados pelo mock
# e estas variaveis sao ignoradas; preencha para testnet/mainnet.
VRF_COORDINATOR=""
VRF_SUB_ID=""
VRF_KEY_HASH="0xd89b2bf150e3b9e13446986e571fb9cab24b13cea0a43ea20a6049a85cc807cc"
VRF_CALLBACK_GAS_LIMIT="500000"
VRF_REQUEST_CONFIRMATIONS="3"

# Deploy local (scripts/deploy.ts): mantem o deployer como owner (util para o
# harness de stress em localhost); "1" para ativar.
KEEP_DEPLOYER_OWNER=""

# Upgrade de proxies (scripts/upgrade.ts): enderecos dos proxies a atualizar.
# Opcional; localhost le automaticamente de scripts/deployed-localhost.json.
TOKEN_PROXY=""
NFT_PROXY=""
STAKING_PROXY=""
MARKETPLACE_PROXY=""
# Restringe scripts/upgrade.ts a um unico proxy (token|nft|staking|marketplace).
UPGRADE_ONLY=""

# scripts/forge-helper.ts (chamada manual de forge)
FORGE_TIER="0"
FORGE_REFERRER="0"
FORGE_NAME="TestChicken"

# scripts/fund-local.ts (financia uma carteira extra no localnet, alem das
# contas padrao do Anvil)
FUND_ADDRESS=""
FUND_AMOUNT="10000"
