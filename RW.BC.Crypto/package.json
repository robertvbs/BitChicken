{
  "name": "rw.bc.crypto",
  "version": "1.0.0",
  "description": "BitChicken Crypto",
  "author": "Robert Wagner",
  "license": "MIT",
  "homepage": "https://github.com/robertvbs/BitChicken",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertvbs/BitChicken.git",
    "directory": "RW.BC.Crypto"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "hardhat test mocha",
    "compile": "hardhat clean && hardhat compile",
    "start": "hardhat clean && hardhat node",
    "node:up": "docker compose up -d",
    "node:down": "docker compose down",
    "node:reset": "docker compose down -v && docker compose up -d",
    "deploy:localhost": "hardhat run scripts/deploy.ts --network localhost",
    "seed:localhost": "hardhat run scripts/seed-local.ts --network localhost",
    "seed-nfts:localhost": "hardhat run scripts/seed-nfts-local.ts --network localhost",
    "seed-market:localhost": "hardhat run scripts/seed-market-local.ts --network localhost",
    "fund:localhost": "hardhat run scripts/fund-local.ts --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network bscMainnet",
    "validate-upgrade": "hardhat run scripts/validate-upgrade.ts",
    "upgrade:localhost": "hardhat run scripts/upgrade.ts --network localhost",
    "upgrade:testnet": "hardhat run scripts/upgrade.ts --network bscTestnet",
    "upgrade:mainnet": "hardhat run scripts/upgrade.ts --network bscMainnet",
    "interact:localhost": "hardhat run scripts/interact.ts --network localhost",
    "interact:testnet": "hardhat run scripts/interact.ts --network bscTestnet",
    "interact:mainnet": "hardhat run scripts/interact.ts --network bscMainnet",
    "verify:mainnet": "hardhat run scripts/verify.ts --network bscMainnet",
    "forge:localhost": "hardhat run scripts/forge-helper.ts --network localhost",
    "forge:watch": "hardhat run scripts/forge-watch.ts --network localhost",
    "stress:localhost": "hardhat run scripts/stress-localnet.ts --network localhost",
    "lint": "solhint 'contracts/**/*.sol' && eslint .",
    "format": "prettier --write 'contracts/**/*.sol' '**/*.ts'",
    "test:invariants": "forge test --match-path 'foundry-test/invariants/*'",
    "coverage:forge": "forge coverage --match-path 'foundry-test/invariants/*' --ir-minimum --report summary"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.5.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@openzeppelin/hardhat-upgrades": "^4.0.2",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "chai": "^6.2.2",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "ethers": "^6.16.0",
    "globals": "^17.6.0",
    "hardhat": "^3.9.0",
    "jiti": "^2.7.0",
    "mocha": "^11.7.6",
    "prettier": "^3.8.4",
    "prettier-plugin-solidity": "^2.3.1",
    "solhint": "^6.2.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0"
  }
}
